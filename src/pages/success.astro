---
import '../styles/global.css';
---

<html lang="en">
<head>
    <title>Success | Comboni Aero Club</title>
</head>
<body class="bg-slate-950 text-white flex items-center justify-center min-h-screen font-sans">
    <div class="max-w-md w-full text-center p-10 bg-slate-900 border border-slate-800 rounded-3xl shadow-2xl">
        <div class="w-20 h-20 bg-blue-500/20 text-blue-500 rounded-full flex items-center justify-center mx-auto mb-6">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-10 w-10" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7" />
            </svg>
        </div>
        <h1 class="text-3xl font-black mb-4">You're Registered!</h1>
        <p class="text-slate-400 mb-8 leading-relaxed">
            Welcome to the **Comboni Aero Club**. Your application has been received. 
            Please visit the office to collect your official **Aero Club T-Shirt**.
        </p>
        <a href="/" class="inline-block bg-blue-600 hover:bg-blue-500 text-white px-8 py-3 rounded-xl font-bold transition-all">
            Return Home
        </a>
    </div>
</body>
</html>